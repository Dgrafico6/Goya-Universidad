        { "Azul", new List<string> { "#0000AA", "#0000FF", "#003E9B", "#0040DB", "#004284", "#0055A7", "#0060FF", "#0641EA", "#0612AB", "#0B4C92", "#10069F", "#112939", "#11479F", "#1B2A3C", "#1B306B", "#192EEF", "#213787", "#2200FF", "#2A84CC", "#2B293D", "#2B3D58", "#2E364D", "#333F48", "#385585", "#395668", "#3CA7FA", "#3D53CA", "#434A5F", "#440099", "#465C7F", "#46749A", "#485CC7", "#4B5664", "#4B665E", "#567CBB", "#586883" } },
        { "Morado", new List<string> { "#381258", "#381286", "#4E008E", "#4F0F70", "#8C3EC8", "#990099", "#A94463", "#B098C4", "#B695C0", "#BB29BB", "#CF78AA", "#D6B2D0" } },
        { "Rosa", new List<string> { "#E5C2CA", "#E6007E", "#EDDBEB", "#F172C6", "#FE7CDD", "#FF83B6", "#FFBF9F" } },
        { "Vino", new List<string> { "#0F0F70", "#671627", "#6A2C36", "#A01A40", "#B56A6E" } },
        { "Marron", new List<string> { "#2D2926", "#402020", "#4E3629", "#4F2832", "#4F2C1D", "#502C1E", "#54415E", "#5E2A2B", "#5E5145", "#683C11", "#6A2C36", "#6A3643", "#6B2830", "#744F28", "#776E64", "#776F48", "#77725A", "#78564C", "#786748", "#7A6E66", "#7B6A58", "#84754E", "#86754D", "#8C7732", "#936037", "#946037", "#956C58", "#997777", "#998677", "#9E9E7D", "#A17F4D", "#A35330", "#A89968", "#AC8F87", "#AD7C59", "#AE8A79", "#AFA9A0", "#B17F4A", "#B2A8A2", "#B78D5B", "#B78D6B", "#B9975B", "#BF9474", "#C09C83", "#C1B2B6", "#C2AF9E", "#C29E85", "#C2BDA3", "#C4BDA3", "#C4BFB6", "#C5A28E", "#C5B783", "#CBA052", "#CDBA78", "#CEA886", "#CEBC71", "#D3BBA8", "#D3BCA4", "#D3BC8D", "#D5A286", "#D5D3BF", "#D7C69E", "#D8BA9A", "#D9B48F", "#DDCBA4", "#DFD1A7", "#E1B87F", "#E2DAC6", "#E2DEE0", "#E3CA99", "#EFCFAC" } },
        { "Negro", new List<string> { "#000000", "#1C1C1E", "#1C1F2A", "#1D1D1B", "#25282A", "#2C2C2C", "#393939", "#4C4C4C", "#54585A", "#56595B", "#575756", "#656565", "#666666", "#6D7276", "#727272", "#7A7A7A", "#857874", "#898989", "#8C857B", "#8E8F90", "#978C87", "#9D968D", "#9D9D9C", "#A2AAAD", "#A4A4A4", "#A8A99E", "#AAADAA", "#AAAAAA", "#ACACAC", "#B2B4B2", "#B2B5B7", "#B8B8B8", "#B9B7BD", "#BEBEBE", "#C1C6C8", "#C4BCB7", "#C7C9C7", "#D0D3D4", "#D3D3D3", "#DBDCDB" } },
        { "Gris", new List<string> { "#000000", "#1c1c1e", "#1c1f2a", "#1d1d1b", "#25282a", "#2c2c2c", "#393939","#4c4c4c", "#54585a", "#56595b", "#575756", "#656565", "#666666", "#6d7276","#727272", "#7a7a7a", "#857874", "#898989", "#8c857b", "#8e8f90", "#978c87","#9d968d", "#9d9d9c", "#a2aaad", "#a4a4a4", "#a8a99e", "#aaadaa", "#aaaaaa","#acacac", "#b2b4b2", "#b2b5b7", "#b8b8b8", "#b9b7bd", "#bebebe", "#c1c6c8","#c4bcb7", "#c7c9c7", "#d0d3d4", "#d3d3d3", "#dbdcdb","#1C1C1E", "#1C1F2A", "#1D1D1B", "#25282A", "#2C2C2C", "#393939", "#4C4C4C", "#54585A", "#56595B", "#575756", "#656565", "#666666", "#6D7276", "#727272", "#7A7A7A", "#857874", "#898989", "#8C857B", "#8E8F90", "#978C87", "#9D968D", "#9D9D9C", "#A2AAAD", "#A4A4A4", "#A8A99E", "#AAADAA", "#AAAAAA", "#ACACAC", "#B2B4B2", "#B2B5B7", "#B8B8B8", "#B9B7BD", "#BEBEBE", "#C1C6C8", "#C4BCB7", "#C7C9C7", "#D0D3D4", "#D3D3D3", "#DBDCDB"} },
