@{
    Layout = "_ColumnsOne";

    //title
    NopHtml.AddTitleParts(T("PageTitle.PageNotFound").Text);
    //page class
    NopHtml.AppendPageCssClassParts("html-not-found-page");
}

@*Customer breadcrumb*@
@section Breadcrumb
{
    <div class="page-title page-title--overlap">
        <div class="page-title__container">
            <div class="page-title__navigation">
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb flex-lg-nowrap justify-content-center justify-content-lg-start" itemscope itemtype="http://schema.org/BreadcrumbList">
                        <li class="breadcrumb-item">
                            <a class="text-nowrap" href="@Url.RouteUrl("Homepage")" title="@T("Categories.Breadcrumb.Top")"><i class="bi bi-house-door"></i> Home</a>
                        </li>
                        <li class="breadcrumb-item text-nowrap active" itemprop="itemListElement" itemscope itemtype="http://schema.org/ListItem">
                            <span class="current-item" itemprop="name">@T("PageTitle.PageNotFound")</span>
                            <span itemprop="item" itemscope itemtype="http://schema.org/Thing" id="@Url.RouteUrl("PageNotFound")"></span>
                            @await Component.InvokeAsync("Widget", new { widgetZone = PublicWidgetZones.ProductBreadcrumbAfter, additionalData = Model })
                        </li>
                    </ol>
                </nav>
            </div>
            <div class="page-title__text">
                <h1 class="h3 mb-0">@T("PageTitle.PageNotFound")</h1>
            </div>
        </div>
    </div>
}
<div class="page not-found-page">
    <div class="page-body bg-light mb-5">
        <div class="row mb-5">
            <div class="col-md-5 d-flex align-items-center">
                <img src="/images/common/404-goya.png" alt="@T("PageTitle.PageNotFound")" class="img-fluid not-found-image" /> 
            </div>
            <div class="col-md-7">
                @await Component.InvokeAsync("TopicBlock", new { systemName = "PageNotFound" })
            </div>
        </div>
    </div>

</div>
