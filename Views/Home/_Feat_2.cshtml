@using Nop.Core
@using Nop.Services.Customers
@inject IWorkContext workContext
@inject ICustomerService customerService
@{
    var userIsRegistered = await customerService.IsRegisteredAsync(await workContext.GetCurrentCustomerAsync());
}

<style>
    .hero-link {
        display: block;
        width: 100%;
        height: 600px;
        position: relative;
        overflow: hidden;
        cursor: pointer;
    }

    .hero-bg {
        position: absolute;
        inset: -80px 0;
        background-image: url(@T("goya.theme.navarra.hero.bg.button.text"));
        background-size: cover;
        background-position: center;
        filter: brightness(0.85);
        transition: filter 0.3s ease;
        will-change: transform;
    }

    .hero-link:hover .hero-bg {
        filter: brightness(0.72);
    }

    .hero-overlay {
        position: absolute;
        inset: 0;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        padding-bottom: 6%;
    }

    .hero-title {
        font-size: clamp(1.8rem, 4vw, 3rem);
        font-weight: 700;
        color: #fff;
        text-align: center;
        letter-spacing: 0.03em;
        margin: 0 0 1.4rem;
        text-shadow: 0 2px 18px rgba(0,0,0,0.45);
        max-width: 640px;
        padding: 0 1rem;
        line-height: 1.2;
    }

    .hero-btn {
        display: inline-block;
        padding: 0.75rem 2.2rem;
        background: #fff;
        color: #1a1a1a;
        font-size: 0.9rem;
        font-weight: 600;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        text-decoration: none;
        border-radius: 2px;
        transition: background 0.25s, color 0.25s, transform 0.2s;
    }

    .hero-btn:hover {
        background: #1a1a1a;
        color: #fff;
        transform: translateY(-2px);
    }
</style>

<section class="hero-banner-section">
    <div class="hero-link" onclick="window.open('@T("goya.theme.home.customsection2.video.href")', '_blank')">
        <div class="hero-bg" id="heroBg"></div>
        <div class="hero-overlay">
            <h2 class="hero-title">@T("goya.theme.home.customsection2.title.text")</h2>
            @if (userIsRegistered)
            {
                <a href="@(Url.RouteUrl("Customizer"))"
                    class="hero-btn"
                    onclick="event.stopPropagation()">
                    @T("goya.theme.home.customsection2.button.text")
                </a>
            }
        </div>
    </div>
</section>

<script>
    (function () {
        const bg = document.getElementById('heroBg');
        if (!bg) return;

        function onScroll() {
            const section = bg.closest('.hero-link');
            const rect = section.getBoundingClientRect();
            const visible = rect.top < window.innerHeight && rect.bottom > 0;
            if (!visible) return;

            const progress = (window.innerHeight - rect.top) / (window.innerHeight + rect.height);
            const offset = (progress - 0.7) * 400;
            bg.style.transform = `translateY(${offset}px)`;
        }

        window.addEventListener('scroll', onScroll, { passive: true });
        onScroll();
    })();
</script>



