<script>
document.addEventListener('DOMContentLoaded', function () {
    const slider = document.querySelector('.tns-carousel-inner.banner-home__inner');
    if (!slider) return;

    const videos = slider.querySelectorAll('video.slide-video');

  // Estado inicial: listos pero parados
    videos.forEach(v => {
    v.setAttribute('preload', 'metadata'); // carga ligera
    v.muted = true;
    v.playsInline = true;
    try { v.pause(); } catch(_) {}
    v.currentTime = 0;
});

  // ¿La diapositiva de este vídeo es la activa del slider?
    const isActiveSlide = (video) => {
    const slide = video.closest('.banner-home__item');
    return slide && slide.classList.contains('tns-slide-active');
};

  // Reglas de reproducción
    const handlePlayState = (video, ratioInView = 0) => {
    const shouldPlay = ratioInView >= 0.5 && isActiveSlide(video);
    if (shouldPlay) {
        video.play().catch(() => {}); // evitar errores de autoplay
    } else {
        if (!video.paused) {
        try { video.pause(); } catch(_) {}
      }
      // "Preparado" para cuando vuelva a salir
      if (!video.seeking) video.currentTime = 0;
    }
  };

  // Observa si cada vídeo está en viewport (al menos 50%)
  const io = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      handlePlayState(entry.target, entry.intersectionRatio);
    });
  }, { threshold: [0, 0.5, 1] });

  videos.forEach(v => io.observe(v));

  // Recalcular al hacer scroll/resize (por si cambia el ratio visible)
  const recomputeAll = () => {
    videos.forEach(v => {
      const rect = v.getBoundingClientRect();
      const visiblePx = Math.max(0, Math.min(rect.bottom, window.innerHeight) - Math.max(rect.top, 0));
      const ratio = rect.height > 0 ? visiblePx / rect.height : 0;
      handlePlayState(v, ratio);
    });
  };
  window.addEventListener('scroll', recomputeAll, { passive: true });
  window.addEventListener('resize', recomputeAll);

  // Detecta cambios de diapositiva (Tiny Slider añade/quita clases)
  const mo = new MutationObserver(recomputeAll);
  mo.observe(slider, { subtree: true, attributes: true, attributeFilter: ['class'] });

  // Si la pestaña pierde el foco, pausa todo
  document.addEventListener('visibilitychange', () => {
    if (document.hidden) {
      videos.forEach(v => { try { v.pause(); } catch(_) {} });
    } else {
      recomputeAll();
    }
  });

  // Primera evaluación
  recomputeAll();
});

//----------------------------------------------------------------------------------//


</script> 