@model IList<ProductDetailsModel.TierPriceModel>

@if (Model.Count > 0)
{
    <div class="mb-3">
        <div class="mb-3">
            <span class="fs-lg">@T("Products.TierPrices"):</span>
        </div>
        
        <div class="table-responsive">
            <table class="table table-sm fs-md">
                <thead>
                    <tr>
                        <th>@T("Products.TierPrices.Quantity")</th>
                        @foreach (var tierPrice in Model)
                        {
                            <th>@(tierPrice.Quantity)+</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>
                            @T("Products.TierPrices.Price")
                        </td>
                        @foreach (var tierPrice in Model)
                        {
                            <td>@tierPrice.Price</td>
                        }
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
} 