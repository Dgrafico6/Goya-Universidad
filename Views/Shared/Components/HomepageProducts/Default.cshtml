@model IList<ProductOverviewModel>
@if (Model.Count > 0)
{
    <div class="container product-grid home-page-product-grid mb-5" style="display: none"> <!-- Este display none es lo que hace que no se vea -->
        <h3 class="text-center text-sm-start text-accent pb-3 display-7">@T("Homepage.Products")</h3>
        <div class="owl-carousel owl-goya-theme">
            @foreach (var item in Model)
            {
                @await Html.PartialAsync("_ProductBox", item)
            }
        </div>
    </div>

    <script type="text/javascript" asp-location="Footer">
        $(document).ready(function(){
          $(".owl-carousel").owlCarousel({
            loop:false,
            margin:16,
            nav:true,
            dots:false,
            navText:"",
            responsive:{
                0:{
                    items:1
                },
                500:{
                    items:2
                },
                768:{
                    items:3
                },
                992:{
                    items:4
                },
                1200:{
                    items:5
                }
            }
          });

        });
    </script>
        
}