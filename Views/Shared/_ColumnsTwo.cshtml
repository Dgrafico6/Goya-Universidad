<style>
    /* En móvil: ancho completo (por defecto) */
    #shop-sidebar {
        max-width: 100%;
        width: 100%;
    }
    
    /* En desktop: 33% */
    @@media (min-width: 992px) {
        #shop-sidebar {
            max-width: 33%;
