@using Nop.Core
@using Nop.Services.Customers
@inject IWorkContext workContext
@inject ICustomerService customerService
@{
    var userIsRegistered = await customerService.IsRegisteredAsync(await workContext.GetCurrentCustomerAsync());
}

<style>
/* Contenedor con fondo */
.img-wrapper {
    width: 100%;
    background-color: var(--bs-accent);

    display: inline-block; /* 🔥 clave */
    text-align: center;

    transition: background-color 0.6s ease;
    cursor: pointer;
}

/* Imagen */
.img-wrapper img {
    width: 100%;
    height: auto;   /* 🔥 mantiene proporción */
    display: block;
}

/* Hover */
.img-wrapper:hover {
    background-color: var(--complementary-color);
}

</style>

<div class="container-fluid px-0">
    <div class="row g-0">
        <div class="mt-8 p-4 col-6 col-sm-3">
            <h2 class="text-center">@T("goya.theme.navarra.landinguniversities.title1")</h2>

            <div class="img-wrapper">
                <img src="@T("goya.theme.navarra.landinguniversities.image1")" alt="Campus Pamplona" class="class="img-fluid w-100"">
            </div>
        </div>


        <div class="mt-8 p-4 col-6 col-sm-3">
            <h2 class="text-center">@T("goya.theme.navarra.landinguniversities.title2")</h2>

            <div class="img-wrapper">
            <img src="@T("goya.theme.navarra.landinguniversities.image2")" alt="Campus San Sebastián" class="img-fluid w-100">
            </div>
        </div>


        <div class="mt-8 p-4 col-6 col-sm-3">
            <h2 class="text-center">@T("goya.theme.navarra.landinguniversities.title3")</h2>

            <div class="img-wrapper">
            <img src="@T("goya.theme.navarra.landinguniversities.image3")" alt="Campus Madrid" class="img-fluid w-100">
            </div>
        </div>


        <div class="mt-8 p-4 col-6 col-sm-3">
            <h2 class="text-center">@T("goya.theme.navarra.landinguniversities.title4")</h2>

            <div class="img-wrapper">
            <img src="@T("goya.theme.navarra.landinguniversities.image4")" alt="Campus IESE" class="img-fluid w-100">
            </div>
        </div>
    </div>
</div>


