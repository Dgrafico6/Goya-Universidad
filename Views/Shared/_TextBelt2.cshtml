<div style="background: lightblue; padding: 20px;">
    <p>Componente Text Belt funcionando ✔️</p>
</div>

@{
    string linkUrl = "https://www.ggoya.com/es";
    string linkText = "HOLA HOLA";

    if (ViewData["LinkUrl"] is string url) { linkUrl = url; }
    if (ViewData["LinkText"] is string txt) { linkText = txt; }
}



<!-- Contenedor -->
<div class="text-belt-wrapper">
    <div class="text-belt">
        <div class="text-track">
            @for (int i = 0; i < 16; i++)
            {
                <a href="@linkUrl" class="text-item">@linkText</a>
            }
        </div>
    </div>
</div>
